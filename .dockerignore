# =============================================================================
# .dockerignore สำหรับ RichPayment Project
# =============================================================================
# ไฟล์และโฟลเดอร์ที่ไม่ต้องส่งเข้า Docker build context
# ช่วยให้ build เร็วขึ้นและลดขนาด context ที่ส่งไป Docker daemon
# =============================================================================

# ---------------------------------------------------------------------------
# Version Control - ไม่ต้องเอา git history เข้า container
# ---------------------------------------------------------------------------
.git
.gitignore

# ---------------------------------------------------------------------------
# Docker files - ไม่จำเป็นใน build context (recursive prevention)
# ---------------------------------------------------------------------------
docker-compose.yml
docker-compose.*.yml
.dockerignore

# ---------------------------------------------------------------------------
# IDE / Editor files - config ของ editor ไม่เกี่ยวกับ production
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Documentation - เอกสารไม่จำเป็นใน container
# ---------------------------------------------------------------------------
*.md
LICENSE
docs/

# ---------------------------------------------------------------------------
# OS generated files - ไฟล์ที่ OS สร้างขึ้นเอง
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Test files - ไม่ต้อง include test files ใน production build
# ---------------------------------------------------------------------------
**/*_test.go
**/testdata/
**/testutil/

# ---------------------------------------------------------------------------
# Build artifacts - ไม่ต้องเอา binary เก่าเข้าไป
# ---------------------------------------------------------------------------
**/bin/
**/dist/

# ---------------------------------------------------------------------------
# Scripts & configs ที่ไม่จำเป็นตอน build
# ---------------------------------------------------------------------------
scripts/
Makefile

# ---------------------------------------------------------------------------
# Environment files - ห้ามเอา secrets เข้า container เด็ดขาด!
# ---------------------------------------------------------------------------
.env
.env.*
*.env

# ---------------------------------------------------------------------------
# Temporary files
# ---------------------------------------------------------------------------
tmp/
*.tmp
*.log
