# =============================================================================
# Environment Variables สำหรับ Development (ตัวแปรสภาพแวดล้อมสำหรับพัฒนา)
# =============================================================================
#
# ไฟล์นี้เก็บค่า environment variables ทั้งหมดที่ต้องใช้รัน services บน localhost
# This file stores all environment variables needed to run services on localhost.
#
# วิธีใช้ / Usage:
#   source .env.dev                     # โหลดตัวแปรเข้า shell ปัจจุบัน
#   export $(grep -v '^#' .env.dev | xargs)  # โหลดแบบ export ทุกตัว
#   make run-gateway                    # Makefile โหลดค่าเองอัตโนมัติ
#
# หมายเหตุ / Notes:
#   - ค่าทั้งหมดเป็นค่าสำหรับ development เท่านั้น (อย่าใช้ใน production!)
#   - All values are for development only (DO NOT use in production!)
#   - ไฟล์นี้ไม่ควร commit ถ้ามี secret จริง (ตอนนี้ใช้ค่า dev ปลอดภัย)
#   - This file should not be committed if it contains real secrets
#
# =============================================================================

# =============================================================================
# Database (ฐานข้อมูล PostgreSQL)
# =============================================================================

# PostgreSQL connection string สำหรับเชื่อมต่อ database
# format: postgres://username:password@host:port/dbname?options
# - richpayment = username ที่สร้างใน docker-compose.dev.yml
# - richpayment_dev = password ที่ตั้งใน docker-compose.dev.yml
# - localhost:5432 = เชื่อมผ่าน host เพราะ PostgreSQL รันใน Docker แต่เปิด port ให้ host
# - sslmode=disable = ไม่ใช้ SSL ใน dev (ใช้ SSL ใน production!)
DATABASE_URL=postgres://richpayment:richpayment_dev@localhost:5432/richpayment?sslmode=disable

# =============================================================================
# Redis (แคชและ Session Store)
# =============================================================================

# Redis connection string สำหรับเชื่อมต่อ Redis
# format: redis://:password@host:port/db_number
# - richpayment_dev = password ที่ตั้งใน docker-compose.dev.yml (redis-server --requirepass)
# - localhost:6379 = เชื่อมผ่าน host
# - /0 = ใช้ database หมายเลข 0 (Redis มี 16 databases: 0-15)
REDIS_URL=redis://:richpayment_dev@localhost:6379/0

# =============================================================================
# NATS (Message Broker)
# =============================================================================

# NATS connection string สำหรับเชื่อมต่อ NATS JetStream
# - ไม่มี authentication ใน dev (เพิ่ม auth ใน production!)
# - localhost:4222 = NATS client port ที่เปิดจาก Docker
NATS_URL=nats://localhost:4222

# =============================================================================
# JWT Configuration (การตั้งค่า JSON Web Token)
# =============================================================================

# Secret key สำหรับ sign JWT tokens
# ใช้สำหรับ HMAC-SHA256 signature
# ใน production ต้องเปลี่ยนเป็น random string ยาวอย่างน้อย 32 characters!
# In production, change to a random string at least 32 characters long!
JWT_SECRET=dev-jwt-secret-change-in-production

# ระยะเวลาหมดอายุของ JWT token (format: Go duration เช่น 24h, 30m, 1h30m)
# JWT token expiry duration (format: Go duration e.g., 24h, 30m, 1h30m)
JWT_EXPIRY=24h

# =============================================================================
# Inter-Service Authentication (การยืนยันตัวตนระหว่าง services)
# =============================================================================

# Secret key ที่ services ใช้ยืนยันตัวตนกันเอง (service-to-service auth)
# ส่งใน header X-Internal-Secret เมื่อ service หนึ่งเรียก service อื่น
# Secret key for service-to-service authentication
# Sent in X-Internal-Secret header when one service calls another
INTERNAL_API_SECRET=dev-internal-secret-change-in-production

# =============================================================================
# External API Keys (API keys สำหรับบริการภายนอก)
# =============================================================================

# Telegram Bot API token - สร้างจาก @BotFather บน Telegram
# ว่างเปล่าสำหรับ dev (ใส่ค่าจริงเมื่อต้องการทดสอบ Telegram bot)
# Telegram Bot API token - create via @BotFather on Telegram
# Empty for dev (add real token when testing Telegram bot)
TELEGRAM_BOT_TOKEN=

# EasySlip API key - สำหรับตรวจสอบสลิปโอนเงิน
# ว่างเปล่าสำหรับ dev (ใส่ค่าจริงเมื่อต้องการทดสอบ slip verification)
# EasySlip API key - for verifying bank transfer slips
# Empty for dev (add real key when testing slip verification)
EASYSLIP_API_KEY=

# =============================================================================
# Webhook Configuration (การตั้งค่า webhook)
# =============================================================================

# จำนวนครั้งสูงสุดที่จะ retry ส่ง webhook เมื่อส่งไม่สำเร็จ
# Maximum number of retry attempts when webhook delivery fails
# ใช้ exponential backoff: 10s, 30s, 90s, 270s, 810s
# Uses exponential backoff: 10s, 30s, 90s, 270s, 810s
WEBHOOK_MAX_RETRIES=5

# =============================================================================
# Timezone (เขตเวลา)
# =============================================================================

# เขตเวลาสำหรับ scheduler service และ cron jobs
# Timezone for scheduler service and cron jobs
# ใช้เวลาไทย (UTC+7) / Uses Thai time (UTC+7)
TZ=Asia/Bangkok

# =============================================================================
# Service Ports (พอร์ตของแต่ละ service)
# =============================================================================
#
# แต่ละ service รัน HTTP server บนพอร์ตที่กำหนด
# Each service runs an HTTP server on its assigned port.
# ตรงกับ port mapping ใน docker-compose.yml (production)
# Matches port mapping in docker-compose.yml (production)
#

# Gateway Service - API Gateway จุดเข้าหลักของระบบ
# Gateway Service - main API entry point
GATEWAY_PORT=8080

# Auth Service - ยืนยันตัวตน JWT/session
# Auth Service - JWT/session authentication
AUTH_PORT=8081

# User Service - จัดการผู้ใช้ (admin, merchant, agent, partner)
# User Service - user management (admin, merchant, agent, partner)
USER_PORT=8082

# Order Service - จัดการรายการฝากเงิน
# Order Service - deposit order management
ORDER_PORT=8083

# Wallet Service - กระเป๋าเงินและบัญชีแยกประเภท
# Wallet Service - wallet and ledger management
WALLET_PORT=8084

# Withdrawal Service - จัดการคำขอถอนเงิน
# Withdrawal Service - withdrawal request management
WITHDRAWAL_PORT=8085

# Parser Service - แปลง SMS ธนาคารเป็นข้อมูล
# Parser Service - parse bank SMS/email into structured data
PARSER_PORT=8086

# Notification Service - ส่ง webhook และแจ้งเตือน
# Notification Service - webhook delivery and alerts
NOTIFICATION_PORT=8087

# Commission Service - คำนวณและแบ่งค่า fee
# Commission Service - fee calculation and commission split
COMMISSION_PORT=8088

# Bank Service - จัดการบัญชีธนาคารสำหรับรับเงิน
# Bank Service - bank account pool management
BANK_PORT=8089

# Telegram Service - ตรวจสอบสลิปผ่าน Telegram bot
# Telegram Service - slip verification via Telegram bot
TELEGRAM_PORT=8090

# Scheduler Service - งานตั้งเวลา (cron jobs)
# Scheduler Service - periodic tasks (cron jobs)
SCHEDULER_PORT=8091

# =============================================================================
# Internal Service URLs (URL ภายในสำหรับ service-to-service communication)
# =============================================================================
#
# URL ที่ services ใช้เรียกหากันเอง
# URLs that services use to call each other.
# ชี้ไปที่ localhost เพราะทุก service รันบน host เครื่องเดียวกัน
# Point to localhost because all services run on the same host machine.
# ใน production (Docker) จะใช้ชื่อ container แทน เช่น http://auth:8081
# In production (Docker), uses container names instead, e.g., http://auth:8081
#

# Auth Service URL - ใช้โดย gateway สำหรับ auth middleware
# Auth Service URL - used by gateway for auth middleware
AUTH_SERVICE_URL=http://localhost:8081

# User Service URL - ใช้โดย withdrawal, commission สำหรับดึงข้อมูล merchant
# User Service URL - used by withdrawal, commission for fetching merchant data
USER_SERVICE_URL=http://localhost:8082

# Order Service URL - ใช้โดย parser, telegram สำหรับแจ้ง match results
# Order Service URL - used by parser, telegram for notifying match results
ORDER_SERVICE_URL=http://localhost:8083

# Wallet Service URL - ใช้โดย order, withdrawal, commission สำหรับจัดการ balance
# Wallet Service URL - used by order, withdrawal, commission for balance management
WALLET_SERVICE_URL=http://localhost:8084

# Withdrawal Service URL - ใช้โดย gateway สำหรับ routing withdrawal requests
# Withdrawal Service URL - used by gateway for routing withdrawal requests
WITHDRAWAL_SERVICE_URL=http://localhost:8085

# Parser Service URL - ใช้โดย gateway สำหรับ routing parse requests
# Parser Service URL - used by gateway for routing parse requests
PARSER_SERVICE_URL=http://localhost:8086

# Notification Service URL - ใช้โดย order สำหรับส่ง webhook หลัง settlement
# Notification Service URL - used by order for sending webhooks after settlement
NOTIFICATION_SERVICE_URL=http://localhost:8087

# Commission Service URL - ใช้โดย order, withdrawal สำหรับคำนวณ fee
# Commission Service URL - used by order, withdrawal for fee calculation
COMMISSION_SERVICE_URL=http://localhost:8088

# Bank Service URL - ใช้โดย order สำหรับเลือกบัญชีรับเงิน, scheduler สำหรับ reset counters
# Bank Service URL - used by order for selecting bank account, scheduler for reset counters
BANK_SERVICE_URL=http://localhost:8089

# Telegram Service URL - ใช้โดย gateway สำหรับ routing telegram webhook
# Telegram Service URL - used by gateway for routing telegram webhook
TELEGRAM_SERVICE_URL=http://localhost:8090

# Scheduler Service URL - ใช้โดย gateway สำหรับ routing scheduler endpoints
# Scheduler Service URL - used by gateway for routing scheduler endpoints
SCHEDULER_SERVICE_URL=http://localhost:8091
